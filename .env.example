# ── Telegram ──────────────────────────────────────────────
BOT_TOKEN=                       # token from @BotFather
WEBHOOK_SECRET=                  # random string; passed to setWebhook and verified on each update

# ── Session ───────────────────────────────────────────────
SESSION_SECRET=                  # random high-entropy string; signs the rx_tg_session cookie.
                                 # REQUIRED in production (set in ALL envs incl. preview). Without
                                 # SESSION_SECRET *and* WEBHOOK_SECRET the app refuses to start
                                 # (fail-closed) instead of signing with a public dev literal.

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=            # https://www.rxteam.pl — canonical origin for email links
                                 # (emailRedirectTo). Pinned here, NOT derived from request Host.

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=                    # https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=             # sb_secret_...  (SERVER ONLY — never expose to browser)

# public (browser) — used by the site later
NEXT_PUBLIC_SUPABASE_URL=        # same as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_...  (safe for browser)

# ── Cron ──────────────────────────────────────────────────
CRON_SECRET=                     # random string; protects /api/cron/* endpoints
