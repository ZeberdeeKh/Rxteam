# ── Telegram ──────────────────────────────────────────────
BOT_TOKEN=                       # token from @BotFather
WEBHOOK_SECRET=                  # random string; passed to setWebhook and verified on each update

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=                    # https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=             # sb_secret_...  (SERVER ONLY — never expose to browser)

# public (browser) — used by the site later
NEXT_PUBLIC_SUPABASE_URL=        # same as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_...  (safe for browser)

# ── Cron ──────────────────────────────────────────────────
CRON_SECRET=                     # random string; protects /api/cron/* endpoints
